# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/order_ahead

# Auth / SMS provider placeholders
PHONE_AUTH_PROVIDER=mock
PHONE_AUTH_API_KEY=replace_me

# App secrets
INTERNAL_API_SECRET=replace_me

# Staff bootstrap (first owner only)
ADMIN_BOOTSTRAP_EMAIL=owner@example.com
ADMIN_BOOTSTRAP_PASSWORD=replace_with_strong_password
ADMIN_BOOTSTRAP_NAME=Owner User
